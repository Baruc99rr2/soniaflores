{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(facebookexternalhit|twitterbot|googlebot|bingbot|Bingbot|linkedinbot|embedly|Prerender|prerender|PrerenderBot)"
        }
      ],
      "destination": "/api/prerender?path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}