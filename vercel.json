{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(facebookexternalhit|Twitterbot|twitterbot|LinkedInBot|linkedinbot|embedly|baiduspider|bingbot|googlebot|Prerender|prerender|PrerenderBot|renderbot|bot|Bot)"
        }
      ],
      "destination": "https://service.prerender.io/https://soniaflores.vercel.app/:1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Prerender-Token",
          "value": "UVfJloBF0H6yuWkL2pYu"
        }
      ]
    }
  ]
}