{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|twitterbot|googlebot|bingbot|linkedinbot|embedly|Prerender|prerender|PrerenderBot|renderbot|bot).*"
        }
      ],
      "destination": "https://service.prerender.io/https://soniaflores.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Prerender-Token",
          "value": "UVfJloBF0H6yuWkL2pYu"
        }
      ]
    }
  ]
}